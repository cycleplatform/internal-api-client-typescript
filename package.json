{
    "name": "@cycleplatform/internal-api-client",
    "version": "0.1.0",
    "description": "A Cycle API client for the internal API inside a container on Cycle.",
    "main": "./dist/index.umd.cjs",
    "module": "./dist/index.js",
    "type": "module",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.js"
            },
            "require": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.umd.cjs"
            }
        }
    },
    "types": "./dist/index.d.ts",
    "files": [
        "dist"
    ],
    "scripts": {
        "test": "vitest",
        "test:ts": "tsc --noEmit",
        "build:client": "openapi-typescript ./api-spec/internal/api.yml --output ./src/generated/types.ts",
        "build:lib": "npm run build:client && vite build",
        "prepare": "vite build",
        "prepublishOnly": "npm run build:lib"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/cycleplatform/internal-api-client-typescript.git"
    },
    "keywords": [
        "cycleplatform",
        "api",
        "client"
    ],
    "author": "Petrichor Holdings, Inc.",
    "license": "Apache-2.0",
    "bugs": {
        "url": "https://github.com/cycleplatform/internal-api-client-typescript/issues"
    },
    "homepage": "https://github.com/cycleplatform/internal-api-client-typescript#readme",
    "dependencies": {
        "openapi-fetch": "0.15.0",
        "undici": "^8.5.0"
    },
    "devDependencies": {
        "msw": "2.14.6",
        "openapi-typescript": "7.13.0",
        "typescript": "5.9.3",
        "vite": "8.0.16",
        "vite-plugin-dts": "5.0.2",
        "vitest": "4.1.9"
    }
}
